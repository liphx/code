# ls
alias l='ls -F'
alias ls='ls --color=auto'
alias la='ls -a'
alias ll='ls -al'

# cd ..
alias ..='cd ..'
alias 2..='cd ../..'
alias 3..='cd ../../..'
alias 4..='cd ../../../..'
alias -- -='cd -'

# interactive
alias cp='cp -i'
alias rm='rm -i'
alias mv='mv -i'

# terminal
alias c=clear

# history
alias h=history
alias r='fc -s'
alias hgrep='history | grep'

# apt 
alias install='sudo apt install'
alias update='sudo apt update && sudo apt upgrade -y'

# alternative
alias diff='colordiff'
alias top='htop'

# git
alias g=git
alias gs='git status -s'
alias gr='git remote -v'
alias ga='git add'
alias gc='git commit -m'
alias gl='git log --oneline -n5'
alias glast='git log -n1'
alias gd='git diff'

# vim
alias vi=vim
alias vimrc='vim ~/.vimrc'
alias vim-default='vim -u NONE -N'

# shorter
alias pu=pushd
alias po=popd

# with args
alias ff='find . -name'
alias j='jobs -l'
alias wget='wget -c'
alias ping='ping -c 4'
alias now='date "+%F %T"'
alias nginxreload='sudo nginx -s reload'
alias nginxtest='sudo nginx -t'
alias tree='tree --charset=ansi'
alias remote='bash ~/.bash/ssh.sh ~/.config/ssh_passwd'
