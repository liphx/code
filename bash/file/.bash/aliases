# ls
alias l='ls -F'
alias ls='ls --color=auto'
alias la='ls -a'
alias ll='ls -al'

# cd ..
alias ..='cd ..'
alias 2..='cd ../..'
alias 3..='cd ../../..'
alias 4..='cd ../../../..'
alias -- -='cd -'

# interactive
alias cp='cp -i'
alias rm='rm -i'
alias mv='mv -i'

# terminal
alias c=clear

# history
alias h=history
alias r='fc -s'
alias hgrep='history | grep'

# apt 
alias install='sudo apt install'
alias update='sudo apt update && sudo apt upgrade'

# find file
alias ff='find . -name $1'

# edit file
alias vimrc='vim ~/.vimrc'

# my software
alias qtcreator='/opt/qtcreator-4.12.4/bin/qtcreator'

alias j='jobs -l'
alias pu=pushd
alias po=popd
alias wget='wget -c'
alias ping='ping -c 4'
alias now='date "+%F %T"'
alias vi=vim
alias nginxreload='sudo nginx -s reload'
alias nginxtest='sudo nginx -t'
alias tree='tree --charset=ansi'

# git
alias g=git
alias gs='git status -s'
alias gv='git remote -v'
alias ga='git add'
alias gc='git commit'
alias gl='git log --oneline -n5'
alias last='git log --oneline -n1'